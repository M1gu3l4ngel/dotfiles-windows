// Coloque sus atajos de teclado en este archivo para sobreescribir los valores predeterminadosauto[]
[
    {
        "key": "ctrl+numpad_divide",
        "command": "editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "shift+alt+a",
        "command": "-editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
    }
]